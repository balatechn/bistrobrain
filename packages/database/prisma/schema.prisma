// =============================================================================
// CUSTOMER & CRM
// =============================================================================

model Customer {
  id              String    @id @default(uuid())
  tenantId        String
  code            String?
  firstName       String
  lastName        String?
  email           String?
  phone           String
  birthday        DateTime?
  anniversary     DateTime?
  address         String?
  city            String?
  pincode         String?
  gender          String?
  notes           String?
  totalOrders     Int       @default(0)
  totalSpent      Decimal   @default(0) @db.Decimal(12, 2)
  loyaltyPoints   Int       @default(0)
  loyaltyTier     String?
  tags            String[]
  isActive        Boolean   @default(true)
  source          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  orders          Order[]
  loyaltyTxns     LoyaltyTransaction[]
  feedbacks       Feedback[]
  campaigns       CustomerCampaign[]

  @@unique([tenantId, phone])
  @@map("customers")
}

model LoyaltyProgram {
  id              String    @id @default(uuid())
  tenantId        String
  name            String
  pointsPerRupee  Decimal   @default(1) @db.Decimal(5, 2)
  rupeePerPoint   Decimal   @default(0.5) @db.Decimal(5, 2)
  minRedeemPoints Int       @default(100)
  expiryDays      Int?
  isActive        Boolean   @default(true)
  tiers           Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id])

  @@map("loyalty_programs")
}

model LoyaltyTransaction {
  id          String    @id @default(uuid())
  customerId  String
  tenantId    String
  orderId     String?
  type        String
  points      Int
  balance     Int
  notes       String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  customer    Customer  @relation(fields: [customerId], references: [id])

  @@map("loyalty_transactions")
}

model Feedback {
  id          String    @id @default(uuid())
  tenantId    String
  branchId    String?
  customerId  String?
  orderId     String?
  rating      Int
  foodRating  Int?
  serviceRating Int?
  ambianceRating Int?
  comment     String?
  source      String?
  isPublished Boolean   @default(false)
  response    String?
  respondedAt DateTime?
  createdAt   DateTime  @default(now())

  customer    Customer? @relation(fields: [customerId], references: [id])

  @@map("feedbacks")
}

model Coupon {
  id              String    @id @default(uuid())
  tenantId        String
  code            String
  name            String
  description     String?
  discountType    String
  discountValue   Decimal   @db.Decimal(10, 2)
