// This file is auto-generated by Prisma. Run `prisma generate` to regenerate.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// TENANT / SAAS CORE
// =============================================================================

model Tenant {
  id                String          @id @default(uuid())
  name              String
  slug              String          @unique
  logo              String?
  email             String          @unique
  phone             String?
  address           String?
  city              String?
  state             String?
  country           String          @default("IN")
  pincode           String?
  gstin             String?
  pan               String?
  fssaiNumber       String?
  currency          String          @default("INR")
  timezone          String          @default("Asia/Kolkata")
  language          String          @default("en")
  dateFormat        String          @default("DD/MM/YYYY")
  timeFormat        String          @default("12")
  fiscalYearStart   Int             @default(4)
  subscriptionPlan  SubscriptionPlan @default(TRIAL)
  subscriptionStatus SubscriptionStatus @default(ACTIVE)
  trialEndsAt       DateTime?
  subscriptionEndsAt DateTime?
  maxBranches       Int             @default(1)
  maxUsers          Int             @default(5)
  maxMenuItems      Int             @default(100)
  isActive          Boolean         @default(true)
  isVerified        Boolean         @default(false)
  settings          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  branches          Branch[]
  users             User[]
  menuCategories    MenuCategory[]
  menuItems         MenuItem[]
  tables            Table[]
  orders            Order[]
  customers         Customer[]
  vendors           Vendor[]
  employees         Employee[]
  inventoryItems    InventoryItem[]
  purchaseOrders    PurchaseOrder[]
  accounts          Account[]
  subscriptions     Subscription[]
  loyaltyPrograms   LoyaltyProgram[]
  taxes             Tax[]
  discounts         Discount[]
  paymentMethods    PaymentMethod[]
  shifts            Shift[]
  coupons           Coupon[]
  activityLogs      ActivityLog[]

  @@map("tenants")
}

model Subscription {
  id              String             @id @default(uuid())
  tenantId        String
  plan            SubscriptionPlan
  status          SubscriptionStatus @default(ACTIVE)
  billingCycle    BillingCycle       @default(MONTHLY)
  amount          Decimal            @db.Decimal(10, 2)
  currency        String             @default("INR")
  startDate       DateTime
  endDate         DateTime
  trialEndDate    DateTime?
  paymentMethod   String?
  transactionId   String?
  invoiceUrl      String?
  autoRenew       Boolean            @default(true)
  addons          Json?
  metadata        Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id])

  @@map("subscriptions")
}

// =============================================================================
// BRANCH MANAGEMENT
// =============================================================================

model Branch {
  id              String    @id @default(uuid())
  tenantId        String
  name            String
  code            String
  address         String?
  city            String?
  state           String?
  pincode         String?
  phone           String?
  email           String?
  gstin           String?
  fssaiNumber     String?
  latitude        Decimal?  @db.Decimal(10, 8)
  longitude       Decimal?  @db.Decimal(11, 8)
  openingTime     String?
  closingTime     String?
  isActive        Boolean   @default(true)
  isCentralKitchen Boolean  @default(false)
  settings        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  users           User[]
  tables          Table[]
  orders          Order[]
  inventoryItems  InventoryItem[]
  stockTransfers  StockTransfer[]
  shifts          Shift[]
  expenses        Expense[]
  employees       Employee[]

  @@unique([tenantId, code])
  @@map("branches")
}

// =============================================================================
// USER MANAGEMENT & RBAC
// =============================================================================

model User {
  id              String    @id @default(uuid())
  tenantId        String
  branchId        String?
  email           String
  phone           String?
  password        String
  firstName       String
  lastName        String
  avatar          String?
  role            UserRole  @default(CASHIER)
  permissions     Json?
  pin             String?
  isActive        Boolean   @default(true)
  isSuperAdmin    Boolean   @default(false)
  mfaEnabled      Boolean   @default(false)
  mfaSecret       String?
  lastLoginAt     DateTime?
  lastLoginIp     String?
  passwordChangedAt DateTime?
  refreshToken    String?
  fcmToken        String?
  language        String    @default("en")
  theme           String    @default("light")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  branch          Branch?   @relation(fields: [branchId], references: [id])
  orders          Order[]   @relation("CreatedByUser")
  kotEntries      KOT[]     @relation("KOTCreatedBy")
  activityLogs    ActivityLog[]
  sessions        UserSession[]

  @@unique([tenantId, email])
  @@map("users")
}

model UserSession {
  id          String    @id @default(uuid())
  userId      String
  token       String    @unique
  ipAddress   String?
  userAgent   String?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id])

  @@map("user_sessions")
}

