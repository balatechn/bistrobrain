}

// =============================================================================
// PURCHASE MANAGEMENT
// =============================================================================

model Vendor {
  id          String    @id @default(uuid())
  tenantId    String
  name        String
  code        String?
  contactName String?
  email       String?
  phone       String
  phone2      String?
  address     String?
  city        String?
  state       String?
  pincode     String?
  gstin       String?
  pan         String?
  bankName    String?
  bankAccount String?
  bankIfsc    String?
  creditDays  Int       @default(0)
  creditLimit Decimal?  @db.Decimal(12, 2)
  outstanding Decimal   @default(0) @db.Decimal(12, 2)
  rating      Int?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  purchaseOrders PurchaseOrder[]
  rateContracts  RateContract[]
  rfqs           RFQ[]
  invoices       PurchaseInvoice[]

  @@unique([tenantId, phone])
  @@map("vendors")
}

model IndentRequest {
  id          String    @id @default(uuid())
  tenantId    String
  branchId    String
  indentNumber String
  requestedById String
  approvedById  String?
  status       String   @default("PENDING")
  priority     String   @default("NORMAL")
  requiredBy   DateTime?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items        IndentItem[]

  @@map("indent_requests")
}

model IndentItem {
  id              String    @id @default(uuid())
  indentId        String
  inventoryItemId String
  requestedQty    Decimal   @db.Decimal(12, 3)
  approvedQty     Decimal?  @db.Decimal(12, 3)
  unit            String
  notes           String?

  indent          IndentRequest @relation(fields: [indentId], references: [id])

  @@map("indent_items")
}

model RFQ {
  id          String    @id @default(uuid())
  tenantId    String
  rfqNumber   String
  indentId    String?
  vendorId    String
  status      String    @default("SENT")
  validTill   DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  vendor      Vendor    @relation(fields: [vendorId], references: [id])
  items       RFQItem[]

  @@map("rfqs")
}

model RFQItem {
  id              String    @id @default(uuid())
  rfqId           String
  inventoryItemId String
  requestedQty    Decimal   @db.Decimal(12, 3)
  quotedQty       Decimal?  @db.Decimal(12, 3)
  quotedPrice     Decimal?  @db.Decimal(10, 2)
  unit            String
  notes           String?

  rfq             RFQ       @relation(fields: [rfqId], references: [id])

  @@map("rfq_items")
}

model RateContract {
  id              String    @id @default(uuid())
  tenantId        String
  vendorId        String
  inventoryItemId String
  rate            Decimal   @db.Decimal(10, 2)
  unit            String
  validFrom       DateTime
  validTo         DateTime
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  vendor          Vendor    @relation(fields: [vendorId], references: [id])

  @@map("rate_contracts")
}

model PurchaseOrder {
  id              String    @id @default(uuid())
  tenantId        String
  branchId        String
  vendorId        String
  poNumber        String
  indentId        String?
  rfqId           String?
  status          String    @default("DRAFT")
  orderDate       DateTime  @default(now())
  deliveryDate    DateTime?
  paymentTerms    String?
  subtotal        Decimal   @db.Decimal(12, 2)
  taxAmount       Decimal   @default(0) @db.Decimal(12, 2)
  discountAmount  Decimal   @default(0) @db.Decimal(12, 2)
  shippingCharge  Decimal   @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal   @db.Decimal(12, 2)
  notes           String?
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  vendor          Vendor    @relation(fields: [vendorId], references: [id])
  items           PurchaseOrderItem[]
  grns            GoodsReceiptNote[]
  invoices        PurchaseInvoice[]

  @@unique([tenantId, poNumber])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String    @id @default(uuid())
  purchaseOrderId String
  inventoryItemId String
  name            String
  quantity        Decimal   @db.Decimal(12, 3)
  receivedQty     Decimal   @default(0) @db.Decimal(12, 3)
  unitPrice       Decimal   @db.Decimal(10, 2)
  taxPercent      Decimal   @default(0) @db.Decimal(5, 2)
  taxAmount       Decimal   @default(0) @db.Decimal(10, 2)
  discountPercent Decimal   @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal   @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal   @db.Decimal(10, 2)
  unit            String
  notes           String?

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@map("purchase_order_items")
}

model GoodsReceiptNote {
  id              String    @id @default(uuid())
  tenantId        String
  branchId        String
  purchaseOrderId String?
  vendorId        String?
  grnNumber       String
  receiptDate     DateTime  @default(now())
  invoiceNumber   String?
  invoiceDate     DateTime?
  vehicleNumber   String?
  status          String    @default("DRAFT")
  subtotal        Decimal   @db.Decimal(12, 2)
  taxAmount       Decimal   @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal   @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  items           GRNItem[]

  @@unique([tenantId, grnNumber])
  @@map("goods_receipt_notes")
}

model GRNItem {
  id              String    @id @default(uuid())
  grnId           String
  inventoryItemId String
  name            String
  orderedQty      Decimal?  @db.Decimal(12, 3)
  receivedQty     Decimal   @db.Decimal(12, 3)
  acceptedQty     Decimal   @db.Decimal(12, 3)
  rejectedQty     Decimal   @default(0) @db.Decimal(12, 3)
  unitPrice       Decimal   @db.Decimal(10, 2)
  taxPercent      Decimal   @default(0) @db.Decimal(5, 2)
  taxAmount       Decimal   @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal   @db.Decimal(10, 2)
  unit            String
  batchNumber     String?
  expiryDate      DateTime?

  grn             GoodsReceiptNote @relation(fields: [grnId], references: [id])

  @@map("grn_items")
}

model PurchaseInvoice {
  id              String    @id @default(uuid())
  tenantId        String
  vendorId        String
  purchaseOrderId String?
  grnId           String?
  invoiceNumber   String
  vendorInvoiceNo String?
  invoiceDate     DateTime
  dueDate         DateTime?
  subtotal        Decimal   @db.Decimal(12, 2)
  taxAmount       Decimal   @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal   @db.Decimal(12, 2)
  paidAmount      Decimal   @default(0) @db.Decimal(12, 2)
  balanceDue      Decimal   @db.Decimal(12, 2)
  status          String    @default("PENDING")
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  vendor          Vendor    @relation(fields: [vendorId], references: [id])
  payments        VendorPayment[]

  @@unique([tenantId, invoiceNumber])
  @@map("purchase_invoices")
}

model VendorPayment {
  id              String    @id @default(uuid())
  tenantId        String
  invoiceId       String
  amount          Decimal   @db.Decimal(12, 2)
  paymentDate     DateTime
  paymentMethod   String
  referenceNumber String?
  notes           String?
  createdAt       DateTime  @default(now())

  invoice         PurchaseInvoice @relation(fields: [invoiceId], references: [id])

  @@map("vendor_payments")
}

// =============================================================================
// FINANCE & ACCOUNTING
// =============================================================================

model Account {
  id            String    @id @default(uuid())
  tenantId      String
  parentId      String?
  code          String
  name          String
  type          AccountType
  subType       String?
  description   String?
  openingBalance Decimal   @default(0) @db.Decimal(14, 2)
  currentBalance Decimal   @default(0) @db.Decimal(14, 2)
  currency      String    @default("INR")
  isSystem      Boolean   @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  parent        Account?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      Account[] @relation("AccountHierarchy")
  journalLines  JournalLine[]

  @@unique([tenantId, code])
  @@map("accounts")
}

model JournalEntry {
  id          String    @id @default(uuid())
  tenantId    String
  branchId    String?
  entryNumber String
  type        String
  date        DateTime
  description String
  referenceType String?
  referenceId   String?
  totalDebit  Decimal   @db.Decimal(14, 2)
  totalCredit Decimal   @db.Decimal(14, 2)
  status      String    @default("POSTED")
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lines       JournalLine[]

  @@unique([tenantId, entryNumber])
  @@map("journal_entries")
}

model JournalLine {
  id              String    @id @default(uuid())
  journalEntryId  String
  accountId       String
  description     String?
  debitAmount     Decimal   @default(0) @db.Decimal(14, 2)
  creditAmount    Decimal   @default(0) @db.Decimal(14, 2)

  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id])
  account         Account   @relation(fields: [accountId], references: [id])

  @@map("journal_lines")
}

model Expense {
  id          String    @id @default(uuid())
  tenantId    String
  branchId    String
  category    String
  amount      Decimal   @db.Decimal(12, 2)
  description String
  expenseDate DateTime
  paidBy      String?
  paymentMethod String?
  receiptUrl  String?
  status      String    @default("APPROVED")
  approvedById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  branch      Branch    @relation(fields: [branchId], references: [id])

  @@map("expenses")
}

// =============================================================================
// TAX MANAGEMENT
// =============================================================================

model Tax {
  id          String    @id @default(uuid())
  tenantId    String
  name        String
  type        String
  rate        Decimal   @db.Decimal(5, 2)
  components  Json?
  hsnCode     String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  menuItems   MenuItem[]

  @@map("taxes")
}

// =============================================================================
// DISCOUNT ENGINE
// =============================================================================

model Discount {
  id              String    @id @default(uuid())
  tenantId        String
  name            String
  type            String
  value           Decimal   @db.Decimal(10, 2)
  minOrderAmount  Decimal?  @db.Decimal(10, 2)
  maxDiscount     Decimal?  @db.Decimal(10, 2)
  applicableTo    String[]
  validFrom       DateTime?
  validTo         DateTime?
  usageLimit      Int?
  usedCount       Int       @default(0)
  isActive        Boolean   @default(true)
  requiresApproval Boolean  @default(false)
  approvalMinRole String?
  createdAt       DateTime  @default(now())

  tenant          Tenant    @relation(fields: [tenantId], references: [id])

  @@map("discounts")
}

// =============================================================================
// HR & PAYROLL
// =============================================================================

model Employee {
  id              String    @id @default(uuid())
  tenantId        String
  branchId        String
  code            String?
  userId          String?
  firstName       String
  lastName        String
  email           String?
  phone           String
  dob             DateTime?
  gender          String?
  address         String?
  designation     String?
  department      String?
  employmentType  String    @default("FULL_TIME")
  joiningDate     DateTime
  leavingDate     DateTime?
  salary          Decimal   @db.Decimal(10, 2)
  salaryType      String    @default("MONTHLY")
  bankName        String?
  bankAccount     String?
  bankIfsc        String?
  panNumber       String?
  aadharNumber    String?
  pfNumber        String?
  esiNumber       String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  branch          Branch    @relation(fields: [branchId], references: [id])
  attendances     Attendance[]
  leaves          LeaveRequest[]
  payrolls        Payroll[]

  @@unique([tenantId, phone])
  @@map("employees")
}

model Shift {
  id          String    @id @default(uuid())
  tenantId    String
  branchId    String
  name        String
  startTime   String
  endTime     String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  branch      Branch    @relation(fields: [branchId], references: [id])

  @@map("shifts")
}

model Attendance {
  id          String    @id @default(uuid())
  employeeId  String
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  workHours   Decimal?  @db.Decimal(4, 2)
  overtime    Decimal   @default(0) @db.Decimal(4, 2)
  status      String    @default("PRESENT")
  source      String    @default("MANUAL")
  notes       String?
  createdAt   DateTime  @default(now())

  employee    Employee  @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@map("attendances")
}

model LeaveRequest {
  id          String    @id @default(uuid())
  employeeId  String
  leaveType   String
  fromDate    DateTime
  toDate      DateTime
  days        Decimal   @db.Decimal(4, 1)
  reason      String?
  status      String    @default("PENDING")
  approvedById String?
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())

  employee    Employee  @relation(fields: [employeeId], references: [id])

  @@map("leave_requests")
}

model Payroll {
  id              String    @id @default(uuid())
  employeeId      String
  tenantId        String
  month           Int
  year            Int
  basicSalary     Decimal   @db.Decimal(10, 2)
  allowances      Json?
  deductions      Json?
  grossSalary     Decimal   @db.Decimal(10, 2)
  netSalary       Decimal   @db.Decimal(10, 2)
  paidDays        Decimal   @db.Decimal(4, 1)
  presentDays     Decimal   @db.Decimal(4, 1)
  overtimeAmount  Decimal   @default(0) @db.Decimal(10, 2)
  pfAmount        Decimal   @default(0) @db.Decimal(10, 2)
  esiAmount       Decimal   @default(0) @db.Decimal(10, 2)
  tdsAmount       Decimal   @default(0) @db.Decimal(10, 2)
  status          String    @default("DRAFT")
  processedAt     DateTime?
  paidAt          DateTime?
  paymentMethod   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  employee        Employee  @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year])
  @@map("payrolls")
}

// =============================================================================
// TABLE RESERVATIONS
// =============================================================================

model Reservation {
  id          String    @id @default(uuid())
  tenantId    String
  branchId    String
  tableId     String?
  customerName String
  phone       String
  email       String?
  guestCount  Int
  date        DateTime
  time        String
  duration    Int       @default(60)
  status      String    @default("CONFIRMED")
  notes       String?
  source      String    @default("WALK_IN")
  reminderSent Boolean  @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  table       Table?    @relation(fields: [tableId], references: [id])

  @@map("reservations")
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

model Notification {
  id          String    @id @default(uuid())
  tenantId    String
  userId      String?
  title       String
  message     String
  type        String
  data        Json?
  channel     String[]
  isRead      Boolean   @default(false)
  readAt      DateTime?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  @@map("notifications")
}

// =============================================================================
// ACTIVITY LOGS & AUDIT TRAIL
// =============================================================================

model ActivityLog {
  id          String    @id @default(uuid())
  tenantId    String
  userId      String?
  action      String
  entity      String
  entityId    String?
  oldData     Json?
  newData     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

// =============================================================================
// ENUMS
// =============================================================================

enum SubscriptionPlan {
  TRIAL
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  MANAGER
  CASHIER
  WAITER
  KITCHEN_STAFF
  INVENTORY_MANAGER
  ACCOUNTANT
  PURCHASE_MANAGER
  HR_MANAGER
  DELIVERY_RIDER
  CUSTOMER
}

enum FoodType {
  VEG
  NON_VEG
  EGG
  VEGAN
}

enum ItemType {
  REGULAR
  COMBO
  ADDON
  MODIFIER
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
  INACTIVE
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
  ONLINE
  DRIVE_THROUGH
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_KITCHEN
  READY
  SERVED
  COMPLETED
  CANCELLED
  VOID
  ON_HOLD
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
  FAILED
  PENDING
}

enum OrderItemStatus {
  PENDING
  IN_PROGRESS
  READY
  SERVED
  CANCELLED
}

enum OrderSource {
  POS
  ONLINE
  MOBILE
  KIOSK
  QR_CODE
  ZOMATO
  SWIGGY
  ONDC
  PHONE
}

enum KOTStatus {
  PENDING
  IN_PROGRESS
  READY
  COMPLETED
  CANCELLED
}

enum KOTItemStatus {
  PENDING
  IN_PROGRESS
  READY
  CANCELLED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}
