# =============================================================================
# Bistro Brain - Restaurant SaaS ERP + POS Platform
# Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME="Bistro Brain"
APP_URL=http://localhost:3000
APP_PORT=3000
API_URL=http://localhost:4000
ADMIN_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bistrobrain?schema=public
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=bistrobrain
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSL=false
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# -----------------------------------------------------------------------------
# REDIS CACHE
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# -----------------------------------------------------------------------------
# JWT AUTHENTICATION
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-change-in-prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# SERVICES PORTS
# -----------------------------------------------------------------------------
AUTH_SERVICE_PORT=4001
POS_SERVICE_PORT=4002
INVENTORY_SERVICE_PORT=4003
FINANCE_SERVICE_PORT=4004
CRM_SERVICE_PORT=4005
PURCHASE_SERVICE_PORT=4006
KITCHEN_SERVICE_PORT=4007
HR_SERVICE_PORT=4008
REPORTING_SERVICE_PORT=4009
NOTIFICATION_SERVICE_PORT=4010
GATEWAY_PORT=4000

# -----------------------------------------------------------------------------
# MICROSERVICE URLS (Internal)
# -----------------------------------------------------------------------------
AUTH_SERVICE_URL=http://localhost:4001
POS_SERVICE_URL=http://localhost:4002
INVENTORY_SERVICE_URL=http://localhost:4003
FINANCE_SERVICE_URL=http://localhost:4004
CRM_SERVICE_URL=http://localhost:4005
PURCHASE_SERVICE_URL=http://localhost:4006
KITCHEN_SERVICE_URL=http://localhost:4007
HR_SERVICE_URL=http://localhost:4008
REPORTING_SERVICE_URL=http://localhost:4009
NOTIFICATION_SERVICE_URL=http://localhost:4010

# -----------------------------------------------------------------------------
# PAYMENT GATEWAYS
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# CLOUD STORAGE (AWS S3 / MinIO)
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=minio
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=bistrobrain-uploads

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=bistrobrain

# -----------------------------------------------------------------------------
# EMAIL (SMTP / SES)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM="Bistro Brain <noreply@bistrobrain.com>"

# -----------------------------------------------------------------------------
# SMS GATEWAY
# -----------------------------------------------------------------------------
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890

MSG91_API_KEY=your-msg91-key
MSG91_SENDER_ID=RSTERP

# -----------------------------------------------------------------------------
# WHATSAPP API
# -----------------------------------------------------------------------------
WHATSAPP_PROVIDER=twilio
WHATSAPP_API_URL=https://api.twilio.com/2010-04-01
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# -----------------------------------------------------------------------------
# FIREBASE (Push Notifications)
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# -----------------------------------------------------------------------------
# BIOMETRIC / HARDWARE
# -----------------------------------------------------------------------------
BIOMETRIC_DEVICE_IP=192.168.1.100
BIOMETRIC_DEVICE_PORT=4370

# -----------------------------------------------------------------------------
# GOOGLE OAUTH
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# SAAS BILLING
# -----------------------------------------------------------------------------
BILLING_CURRENCY=INR
TRIAL_DAYS=14
STARTER_PLAN_PRICE=2999
PROFESSIONAL_PLAN_PRICE=7999
ENTERPRISE_PLAN_PRICE=19999

# -----------------------------------------------------------------------------
# AI SERVICES
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxx
OPENAI_MODEL=gpt-4-turbo-preview
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# THIRD-PARTY AGGREGATORS
# -----------------------------------------------------------------------------
ZOMATO_API_KEY=your-zomato-api-key
SWIGGY_API_KEY=your-swiggy-api-key
ONDC_SUBSCRIBER_ID=your-ondc-id

# -----------------------------------------------------------------------------
# MONITORING & LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
SENTRY_DSN=https://xxx@sentry.io/xxx
NEW_RELIC_LICENSE_KEY=your-new-relic-key

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# -----------------------------------------------------------------------------
# ENCRYPTION
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=your-32-char-encryption-key-here!!
ENCRYPTION_IV=your-16-char-iv!!

# -----------------------------------------------------------------------------
# SUPER ADMIN (First-time setup)
# -----------------------------------------------------------------------------
SUPER_ADMIN_EMAIL=superadmin@bistrobrain.com
SUPER_ADMIN_PASSWORD=Change@123
SUPER_ADMIN_NAME="Super Admin"
